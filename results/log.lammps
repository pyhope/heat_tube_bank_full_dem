fix             feed mobile pour 500000 1 643219 region feed diam range 8e-05 0.00012 dens 3300 ${rho} vel -0.03 0.03 -0.01 0.01 -0.35 vol 0.22 100 id max
fix             feed mobile pour 500000 1 643219 region feed diam range 8e-05 0.00012 dens 3300 3300 vel -0.03 0.03 -0.01 0.01 -0.35 vol 0.22 100 id max
fix             outlet mobile evaporate ${outlet_every} ${outlet_max} outlet ${outlet_seed}
fix             outlet mobile evaporate 1000 ${outlet_max} outlet ${outlet_seed}
fix             outlet mobile evaporate 1000 100000 outlet ${outlet_seed}
fix             outlet mobile evaporate 1000 100000 outlet 928371

timestep        ${dt}
timestep        2e-07

compute         contact_count mobile contact/atom
compute         ke_atom mobile ke/atom
compute         erot_atom mobile erotate/sphere/atom
compute         sum_contact mobile reduce sum c_contact_count
compute         max_contact mobile reduce max c_contact_count
compute         sum_ke mobile reduce sum c_ke_atom
compute         sum_erot mobile reduce sum c_erot_atom
compute         bank_contact mobile_bank reduce sum c_contact_count
compute         bank_ke mobile_bank reduce sum c_ke_atom
compute         bank_erot mobile_bank reduce sum c_erot_atom

variable        nmobile equal count(mobile)
variable        nbank equal count(mobile_bank)
variable        noutlet equal count(mobile_outlet)
variable        dt_s equal ${dt}
variable        dt_s equal 2e-07
variable        sample_dt_s equal ${dt}*${contact_every}
variable        sample_dt_s equal 2e-07*${contact_every}
variable        sample_dt_s equal 2e-07*20000
variable        pre_steps equal ${dump_start}
variable        pre_steps equal 200000
variable        production_steps equal ${dump_stop}-${dump_start}
variable        production_steps equal 600000-${dump_start}
variable        production_steps equal 600000-200000
variable        post_steps equal ${nsteps}-${dump_stop}
variable        post_steps equal 600000-${dump_stop}
variable        post_steps equal 600000-600000

fix             global_out all ave/time ${global_every} 1 ${global_every}                 v_nmobile v_nbank v_noutlet f_outlet c_sum_contact c_max_contact c_sum_ke c_sum_erot c_bank_contact c_bank_ke c_bank_erot                 file global_metrics.dat
fix             global_out all ave/time 2000 1 ${global_every}                 v_nmobile v_nbank v_noutlet f_outlet c_sum_contact c_max_contact c_sum_ke c_sum_erot c_bank_contact c_bank_ke c_bank_erot                 file global_metrics.dat
fix             global_out all ave/time 2000 1 2000                 v_nmobile v_nbank v_noutlet f_outlet c_sum_contact c_max_contact c_sum_ke c_sum_erot c_bank_contact c_bank_ke c_bank_erot                 file global_metrics.dat

thermo          ${thermo_every}
thermo          20000
