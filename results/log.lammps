set             type 2 diameter ${tube_diameter} density ${tube_density}
set             type 2 diameter 0.00014 density ${tube_density}
set             type 2 diameter 0.00014 density 7800
Setting atom values ...
  12474 settings made for diameter
  12474 settings made for density
group           tubes type 2
12474 atoms in group tubes
group           mobile type 1
0 atoms in group mobile

pair_style      gran/hooke/history ${kn} NULL ${gamma} NULL ${mu} 0
pair_style      gran/hooke/history 1000 NULL ${gamma} NULL ${mu} 0
pair_style      gran/hooke/history 1000 NULL 2 NULL ${mu} 0
pair_style      gran/hooke/history 1000 NULL 2 NULL 0.5 0
pair_coeff      * *
neighbor        3.0e-5 bin
neigh_modify    delay 0 every 1 check yes exclude group tubes tubes

fix             int mobile nve/sphere
fix             grav mobile gravity ${g_accel} vector 0 0 -1
fix             grav mobile gravity 9.81 vector 0 0 -1
fix             wallx mobile wall/gran hooke/history ${kn} NULL ${gamma} NULL ${mu} 0 xplane 0.0 ${lx}
fix             wallx mobile wall/gran hooke/history 1000 NULL ${gamma} NULL ${mu} 0 xplane 0.0 ${lx}
fix             wallx mobile wall/gran hooke/history 1000 NULL 2 NULL ${mu} 0 xplane 0.0 ${lx}
fix             wallx mobile wall/gran hooke/history 1000 NULL 2 NULL 0.5 0 xplane 0.0 ${lx}
fix             wallx mobile wall/gran hooke/history 1000 NULL 2 NULL 0.5 0 xplane 0.0 0.012
fix             wally mobile wall/gran hooke/history ${kn} NULL ${gamma} NULL ${mu} 0 yplane 0.0 ${ly}
fix             wally mobile wall/gran hooke/history 1000 NULL ${gamma} NULL ${mu} 0 yplane 0.0 ${ly}
fix             wally mobile wall/gran hooke/history 1000 NULL 2 NULL ${mu} 0 yplane 0.0 ${ly}
fix             wally mobile wall/gran hooke/history 1000 NULL 2 NULL 0.5 0 yplane 0.0 ${ly}
fix             wally mobile wall/gran hooke/history 1000 NULL 2 NULL 0.5 0 yplane 0.0 0.0024

region          feed block ${feed_xlo} ${feed_xhi} ${feed_ylo} ${feed_yhi} ${feed_zlo} ${feed_zhi} units box
region          feed block 0.0005 ${feed_xhi} ${feed_ylo} ${feed_yhi} ${feed_zlo} ${feed_zhi} units box
region          feed block 0.0005 0.0115 ${feed_ylo} ${feed_yhi} ${feed_zlo} ${feed_zhi} units box
region          feed block 0.0005 0.0115 0.0002 ${feed_yhi} ${feed_zlo} ${feed_zhi} units box
region          feed block 0.0005 0.0115 0.0002 0.0022 ${feed_zlo} ${feed_zhi} units box
region          feed block 0.0005 0.0115 0.0002 0.0022 0.0285 ${feed_zhi} units box
region          feed block 0.0005 0.0115 0.0002 0.0022 0.0285 0.031 units box
region          tube_bank block 0 ${lx} 0 ${ly} ${bank_zlo} ${bank_zhi} units box
region          tube_bank block 0 0.012 0 ${ly} ${bank_zlo} ${bank_zhi} units box
region          tube_bank block 0 0.012 0 0.0024 ${bank_zlo} ${bank_zhi} units box
region          tube_bank block 0 0.012 0 0.0024 0.0052 ${bank_zhi} units box
region          tube_bank block 0 0.012 0 0.0024 0.0052 0.0272 units box
region          outlet block 0 ${lx} 0 ${ly} 0 ${outlet_zhi} units box
region          outlet block 0 0.012 0 ${ly} 0 ${outlet_zhi} units box
region          outlet block 0 0.012 0 0.0024 0 ${outlet_zhi} units box
region          outlet block 0 0.012 0 0.0024 0 0.0012 units box
group           mobile_bank dynamic mobile region tube_bank every ${global_every}
group           mobile_bank dynamic mobile region tube_bank every 2000
dynamic group mobile_bank defined
group           mobile_outlet dynamic mobile region outlet every ${global_every}
group           mobile_outlet dynamic mobile region outlet every 2000
dynamic group mobile_outlet defined

fix             feed mobile pour ${npart} 1 643219 region feed diam range ${dlo} ${dhi} dens ${rho} ${rho} vel -0.03 0.03 -0.01 0.01 -0.35 vol 0.22 100 id max
fix             feed mobile pour 500000 1 643219 region feed diam range ${dlo} ${dhi} dens ${rho} ${rho} vel -0.03 0.03 -0.01 0.01 -0.35 vol 0.22 100 id max
fix             feed mobile pour 500000 1 643219 region feed diam range 8e-05 ${dhi} dens ${rho} ${rho} vel -0.03 0.03 -0.01 0.01 -0.35 vol 0.22 100 id max
